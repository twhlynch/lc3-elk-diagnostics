{
	"name": "lc3-elk-diagnostics",
	"displayName": "LC-3 Elk Diagnostics",
	"description": "Diagnostics provider for LC-3 Assembly",
	"version": "0.1.0",
	"repository": "https://github.com/twhlynch/lc3-elk-diagnostics",
	"publisher": "twhlynch",
	"icon": "icon.png",
	"engines": {
		"vscode": "^1.116.0"
	},
	"categories": [
		"Other"
	],
	"activationEvents": [
		"onLanguage:lc3asm"
	],
	"main": "./dist/extension.js",
	"contributes": {
		"commands": [],
		"languages": [
			{
				"id": "lc3asm",
				"aliases": [
					"LC3 Assembly",
					"lc3asm"
				],
				"extensions": [
					".asm"
				],
				"configuration": "./language-configuration.json"
			}
		]
	},
	"scripts": {
		"vscode:prepublish": "npm run package",
		"package": "npm run check && node esbuild.js --production",
		"compile": "npm run check && node esbuild.js",
		"check": "tsc --noEmit && eslint src"
	},
	"devDependencies": {
		"@types/vscode": "^1.116.0",
		"@types/mocha": "^10.0.10",
		"@types/node": "22.x",
		"typescript-eslint": "^8.56.1",
		"eslint": "^9.39.3",
		"esbuild": "^0.27.3",
		"npm-run-all": "^4.1.5",
		"typescript": "^5.9.3",
		"@vscode/test-cli": "^0.0.12",
		"@vscode/test-electron": "^2.5.2"
	}
}
